# ── Nez Backend — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nez_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email (Resend — recommended) ──────────────────────────────────────────────
# Get a free key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Nez <noreply@mail.yourdomain.com>

# ── Email (SMTP — alternative) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this backend (used in verification email links)
APP_BASE_URL=https://your-backend.up.railway.app
